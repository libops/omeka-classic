{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>libops/renovate-config"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "groupName": "container images"
    },
    {
      "matchPackageNames": ["omeka/Omeka"],
      "groupName": "Omeka Classic"
    }
  ]
}

